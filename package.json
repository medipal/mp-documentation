{
  "name": "mp-documentation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "3.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitepress": "^1.6.3",
    "vue": "^3.5.0"
  },
  "lint-staged": {
    "*.{js,ts,vue,json,css,md,yaml,yml}": "prettier --write",
    "*.{js,ts,vue}": "eslint --fix"
  }
}
